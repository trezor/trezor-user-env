# Start with a base Debian image
FROM debian:trixie-slim

# Set environment variables
ENV TERM=xterm \
    XDG_RUNTIME_DIR="/var/tmp" \
    LC_ALL=C.UTF-8 \
    LANG=C.UTF-8 \
    GIT_SSL_CAINFO=/etc/ssl/certs/ca-certificates.crt \
    NIX_SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt \
    DISPLAY=:99

# Install required packages
RUN curl -sL https://deb.nodesource.com/setup_22.x  | bash -
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssl \
    bash \
    git \
    nodejs \
    python3 \
    python3-dev \
    python3-pip \
    python3-venv \
    libsdl2-2.0-0 \
    libsdl2-image-2.0-0 \
    xvfb \
    x11vnc \
    x11-utils \
    novnc \
    websockify \
    xdotool \
    x11-xserver-utils \
    wget \
    unzip \
    curl \
    procps \
    build-essential \
    g++ \
    libc6 \
    libc6-dev \
    patchelf \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Install uv for package management
COPY --from=ghcr.io/astral-sh/uv:0.8.20 /uv /uvx /bin/

# Copy project configuration files
WORKDIR /trezor-user-env
COPY ./pyproject.toml /trezor-user-env/
COPY ./uv.lock /trezor-user-env/
COPY ./.python-version /trezor-user-env/

# Install dependencies with uv (it will create .venv automatically)
RUN uv sync

# Copy the rest of the files
COPY ./ /trezor-user-env

RUN ./src/binaries/firmware/bin/download.sh
RUN ./src/binaries/trezord-go/bin/download.sh
RUN ./src/binaries/node-bridge/download.sh
# Patch emulator binaries
RUN cd src/binaries/firmware/bin && ./patch-bin.sh

# Copy and configure entrypoint
COPY ./docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Add custom Trezor VNC client and patch noVNC lite as a fallback
COPY ./docker/trezor.html /usr/share/novnc/trezor.html
RUN sed -i 's/id="top_bar">/id="top_bar" style="display:none">/' /usr/share/novnc/vnc_lite.html

# Entrypoint starts Xvfb + x11vnc + noVNC, then execs CMD
# Emulator window viewable at http://localhost:6080/vnc.html
ENTRYPOINT ["/entrypoint.sh"]
CMD ["uv", "run", "python", "src/main.py"]
